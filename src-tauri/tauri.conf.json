{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClaudeCue",
  "version": "0.0.1",
  "identifier": "com.claudecue.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ClaudeCue",
        "width": 1280,
        "height": 832,
        "minWidth": 880,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "copyright": "© 2026 ClaudeCue",
    "shortDescription": "Run and manage many live claude CLI sessions.",
    "longDescription": "A macOS desktop app for running and managing many live claude CLI sessions at once — an Overview agent wall of real terminals, a Focus view with a git-diff inspector, and a repo-grouped sidebar.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ErikdeJager/ClaudeCue/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk5N0IwMDExRjYyRTg5NzkKUldSNWlTNzJFUUI3bVV3Z0duQ3NmMkJLRld5cmoyL0tITzQ2NGp6anFsdmpYRkp5MWlqU3BjdzkK"
    }
  }
}
