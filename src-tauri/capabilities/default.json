{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window, detached canvas windows (#84), and full app windows (task 434)",
  "windows": ["main", "canvas-*", "app-*"],
  "permissions": [
    "core:default",
    "dialog:default",
    "updater:default",
    "process:allow-restart",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-read-image",
    "clipboard-manager:allow-write-text",
    "notification:default"
  ]
}
