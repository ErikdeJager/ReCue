{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and detached canvas windows (#84)",
  "windows": ["main", "canvas-*"],
  "permissions": [
    "core:default",
    "dialog:default",
    "updater:default",
    "process:allow-restart",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-read-image"
  ]
}
