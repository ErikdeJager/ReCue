[Desktop Entry]
Type=Application
Name={{name}}
{{#if comment}}
Comment={{comment}}
{{/if}}
Exec={{exec}}
Icon={{icon}}
Terminal=false
Categories={{categories}}
Keywords=claude;agent;ai;terminal;session;developer;
StartupNotify=true
StartupWMClass=recue
{{#if mime_type}}
MimeType={{mime_type}}
{{/if}}
