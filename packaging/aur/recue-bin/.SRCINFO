pkgbase = recue-bin
	pkgdesc = Run and manage many live claude CLI sessions — an agent wall, a split-panel canvas, and a repo-grouped sidebar
	pkgver = 1.2.1
	pkgrel = 1
	url = https://github.com/ErikdeJager/ReCue
	arch = x86_64
	license = custom
	depends = webkit2gtk-4.1
	depends = gtk3
	depends = glib2
	depends = cairo
	depends = gdk-pixbuf2
	depends = libsoup3
	depends = dbus
	depends = glibc
	depends = gcc-libs
	optdepends = claude-code: the Claude Code CLI ReCue runs in every session
	optdepends = git: branch, diff and file-status reading for repo folders
	optdepends = xdg-utils: open links, folders and files in the browser / file manager
	optdepends = xdg-desktop-portal-gtk: native file and folder picker dialogs
	provides = recue
	conflicts = recue
	noextract = ReCue_1.2.1_amd64.deb
	options = !strip
	options = !debug
	source = https://github.com/ErikdeJager/ReCue/releases/download/v1.2.1/ReCue_1.2.1_amd64.deb
	sha256sums = SKIP

pkgname = recue-bin
