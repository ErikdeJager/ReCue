# Re-include this project's .claude/ directory (skills + project settings).
# Overrides the global ~/.config/git/ignore rule that ignores .claude/ everywhere,
# so the project-scoped skills are tracked and shared with the repo.
!.claude/

# This project's CLAUDE.md is committed (the global ignore hides it elsewhere).
!CLAUDE.md

# kanban-dev-pima pipeline: local-only board + per-task plans.
# (ASSUMPTIONS.md and TASK_ARCHIVE.md stay tracked — do not ignore them.)
KANBAN.md
PLAN-*.md

# Isolated agent worktrees (created by the worktree-implementer agent)
.worktree/

# Parallel plan lane: task-planner handbacks + in-flight breadcrumbs
.plan/

# --- Frontend (Vite / React) ---
node_modules
dist
dist-ssr
*.local

# --- Coverage (vitest v8 / cargo-llvm-cov) ---
coverage
lcov.info

# --- Rust / Tauri backend ---
src-tauri/target
src-tauri/gen/schemas

# --- Logs ---
logs
*.log
npm-debug.log*

# --- OS / editor ---
.DS_Store
.idea
.vscode/*
!.vscode/extensions.json
*.suo
*.sw?
