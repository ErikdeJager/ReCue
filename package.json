{
  "name": "recue",
  "private": true,
  "version": "1.1.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "sign:mac": "scripts/sign-macos-local.sh",
    "build:mac": "npm run tauri build && RECUE_CREATE_IDENTITY=1 scripts/sign-macos-local.sh \"$(node -e \"const fs=require('fs');const p=['src-tauri/target/universal-apple-darwin/release/bundle/macos/ReCue.app','src-tauri/target/release/bundle/macos/ReCue.app'].find(f=>fs.existsSync(f));if(!p){console.error('ReCue.app not found — run `npm run tauri build` first');process.exit(1)}process.stdout.write(p)\")\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/jetbrains-mono": "^5.1.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^1.21.0",
    "mermaid": "^11.16.0",
    "prismjs": "^1.30.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "remark-gfm": "^4.0.1",
    "unist-util-visit-parents": "^6.0.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@eslint/js": "^9.18.0",
    "@tauri-apps/cli": "^2",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  }
}
